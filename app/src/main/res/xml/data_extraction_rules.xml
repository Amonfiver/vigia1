<?xml version="1.0" encoding="utf-8"?>
<!--
  Archivo: app/src/main/res/xml/data_extraction_rules.xml
  Propósito: Configurar reglas de extracción de datos para Android 12+ (API 31+).
  Responsabilidad principal: Definir qué datos se incluyen en backups para Android 12 y superior.
  Alcance: Configuración de backup para Android moderno en el MVP.

  Decisiones técnicas relevantes:
  - Permitir backup de preferencias compartidas

  Limitaciones temporales del MVP:
  - Configuración mínima sin exclusiones específicas

  Cambios recientes: Creación inicial.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>