<?xml version="1.0" encoding="utf-8"?>
<!--
  Archivo: app/src/main/AndroidManifest.xml
  Propósito: Definir configuración del paquete Android y permisos necesarios para VIGIA1.
  Responsabilidad principal: Declarar componentes de la app, permisos y configuración de hardware.
  Alcance: Manifest base para MVP de VIGIA1.

  Decisiones técnicas relevantes:
  - Permiso CAMERA para acceso a cámara del dispositivo
  - Permiso INTERNET para comunicación con Telegram Bot API
  - Feature camera.any para indicar uso de cámara (no obligatoria si solo es trasera)
  - android:exported="true" en MainActivity para permitir lanzamiento desde launcher

  Limitaciones temporales del MVP:
  - Sin permisos de foreground service todavía (se añadirán si se necesita servicio persistente)
  - Sin configuración avanzada de backup o seguridad de red

  Cambios recientes: Creación inicial del manifest.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos necesarios para VIGIA1 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Feature de cámara - any permite cámara frontal o trasera -->
    <uses-feature android:name="android.hardware.camera.any" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vigia1"
        tools:targetApi="31">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Vigia1">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
    </application>

</manifest>